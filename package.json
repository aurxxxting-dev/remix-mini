{
  "name": "remix-mini",
  "version": "1.3.7",
  "description": "Remix Mini AI screenshot tool",
  "author": "Remix Mini",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64"
  },
  "build": {
    "appId": "com.remix-mini.image-tool",
    "productName": "Remix Mini",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!assets/*.png",
      "!**/*.map",
      "!agnes.py",
      "!需求.txt",
      "!API规则.txt",
      "!CHANGELOG.md",
      "!README.md",
      "!screenshot.html",
      "!screenshot.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logo.ico"
    },
    "compression": "maximum",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Remix Mini"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.15.3"
  }
}
